{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "specialist-agents": {
            "command": "node",
            "args": [
                "/Users/leads/dev/AI-Specialists /mcp-server/dist/index.js"
            ]
        }
    }
}
